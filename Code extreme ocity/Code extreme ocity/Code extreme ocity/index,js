require("dotenv").config();

const { Client, GatewayIntentBits } = require("discord.js");
const db = require("./database");
const { checkTwitchLive, checkTikTokLive } = require("./utils/liveCheck");
const { validateTitle } = require("./utils/titleCheck");

// Web-Dashboard starten (läuft im selben Prozess)
require("./web/server");

const client = new Client({
  intents: [GatewayIntentBits.Guilds]
});

const liveCache = new Set();
const activity = Object.create(null);

client.once("ready", () => {
  console.log(`🍊 Orange City PRO Bot online: ${client.user.tag}`);
  startLiveChecks();
});

function startLiveChecks() {
  // Alle 60s prüfen
  setInterval(async () => {
    db.all("SELECT * FROM streamers", [], async (err, rows) => {
      if (err) return console.error("DB error:", err);

      for (const s of rows) {
        try {
          if (s.platform === "twitch") {
            const res = await checkTwitchLive(s.name);

            if (res.live && !liveCache.has(`twitch:${s.name}`)) {
              if (!validateTitle(res.title)) continue;

              await sendLiveMessage(s.name, res.url, res.title, "Twitch");
              activity[`twitch:${s.name}`] = (activity[`twitch:${s.name}`] || 0) + 1;

              await checkStreamerPlus(s.name);
              liveCache.add(`twitch:${s.name}`);
            }

            if (!res.live) liveCache.delete(`twitch:${s.name}`);
          }

          if (s.platform === "tiktok") {
            const live = await checkTikTokLive(s.name);

            if (live && !liveCache.has(`tiktok:${s.name}`)) {
              await sendLiveMessage(
                s.name,
                `https://tiktok.com/@${s.name}`,
                "TikTok LIVE",
                "TikTok"
              );

              activity[`tiktok:${s.name}`] = (activity[`tiktok:${s.name}`] || 0) + 1;

              await checkStreamerPlus(s.name);
              liveCache.add(`tiktok:${s.name}`);
            }

            if (!live) liveCache.delete(`tiktok:${s.name}`);
          }
        } catch (e) {
          console.error(`LiveCheck error for ${s.platform}:${s.name}`, e);
        }
      }
    });
  }, 60_000);
}

async function sendLiveMessage(name, url, title, platform) {
  const channelId = process.env.CHANNEL_ID;
  if (!channelId) return console.error("Missing CHANNEL_ID in env");

  // fetch() ist robuster als nur cache.get()
  const channel = await client.channels.fetch(channelId).catch(() => null); // [4](https://stackoverflow.com/questions/76921952/how-can-i-get-the-channel-from-my-interaction-discord-js-v14)[5](https://discord.js.org/docs/packages/discord.js/main/ChannelManager:Class)
  if (!channel) return console.error("Channel not found / no access:", channelId);

  const roleId = process.env.ROLE_ID;
  const ping = roleId ? `<@&${roleId}> ` : "";

  await channel.send({
    content: `${ping}🔴 ${name} ist LIVE auf ${platform}!\n**${title}**\n${url}`
  });
}

async function checkStreamerPlus(name) {
  const plusRoleId = process.env.STREAMERPLUS_ROLE;
  if (!plusRoleId) return;

  // Beispiel: nach 5 Aktivitäten
  const keyTwitch = `twitch:${name}`;
  const keyTikTok = `tiktok:${name}`;
  const count = (activity[keyTwitch] || 0) + (activity[keyTikTok] || 0);

  if (count < 5) return;

  const guild = client.guilds.cache.first();
  if (!guild) return;

  // Member-Cache kann unvollständig sein, deswegen fetch wir die Memberliste nicht komplett,
  // sondern versuchen nur, wenn Member bereits im Cache ist (schont Rate Limits).
  const member = guild.members.cache.find(
    (m) => m.user.username.toLowerCase() === name.toLowerCase()
  );

  if (!member) return;

  await member.roles.add(plusRoleId).catch(() => {});
}

client.login(process.env.DISCORD_TOKEN);
